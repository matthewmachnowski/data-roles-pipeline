# Adzuna API credentials — register at https://developer.adzuna.com/
# Copy this file to .env (gitignored) and fill in your values.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Anthropic API key — used by src/extract.py for the LLM skills/seniority pass.
# Get one at https://console.anthropic.com/. Without it, extract.py still builds
# the deterministic Parquet table and skips the (paid) skills pass.
ANTHROPIC_API_KEY=
